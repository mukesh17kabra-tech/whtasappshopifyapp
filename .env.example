# --- Shopify ---
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://your-app.vercel.app
SCOPES=read_orders,read_customers,write_products

# --- Neon Postgres ---
# Pooled connection (used at runtime by the app, via @neondatabase/serverless)
DATABASE_URL=postgresql://user:pass@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require
# Direct connection (used only for `prisma migrate deploy`)
DIRECT_URL=postgresql://user:pass@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# --- Background jobs (Upstash QStash) ---
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# --- WhatsApp Bridge (default — no Meta approval needed) ---
# Deploy the separate whatsapp-bridge-service (Railway recommended) first,
# then set these to match:
WHATSAPP_BRIDGE_URL=
WHATSAPP_BRIDGE_SECRET=
# Leave unset or "bridge" to use the bridge above. Set to "meta" only if you
# switch to the official Cloud API instead (requires template approval).
WHATSAPP_PROVIDER=bridge

# --- WhatsApp Meta Cloud API (optional fallback, only used if WHATSAPP_PROVIDER=meta) ---
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
# Any random string you choose — must match what you enter in Meta's webhook config
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# --- Vercel Blob (image storage for template headers) ---
# Add the "Blob" storage integration in your Vercel project dashboard
# (Storage tab) — it auto-generates this token, just copy it here.
BLOB_READ_WRITE_TOKEN=
