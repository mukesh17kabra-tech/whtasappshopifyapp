# --- Shopify ---
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://your-app.vercel.app
SCOPES=read_orders,read_customers,write_products,read_fulfillments

# --- Neon Postgres ---
# Pooled connection (used at runtime by the app, via @neondatabase/serverless)
DATABASE_URL=postgresql://user:pass@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require
# Direct connection (used only for `prisma db push`)
DIRECT_URL=postgresql://user:pass@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# --- Background jobs (Upstash QStash) ---
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# --- WhatsApp Bridge (the ONLY way messages send — no Meta involved at all) ---
# Deploy whatsapp-bridge-service separately (see its own README, Railway recommended)
WHATSAPP_BRIDGE_URL=
# Any random string you choose — must match the API_SECRET set on the bridge service
WHATSAPP_BRIDGE_SECRET=

# --- Vercel Blob (image storage for template headers / popup images) ---
# Add the "Blob" storage integration in your Vercel project dashboard
# (Storage tab) — it auto-generates this token, just copy it here.
BLOB_READ_WRITE_TOKEN=

# --- Developer Support Inbox ---
# Any random string you choose — access your support inbox at
# https://your-app.vercel.app/developer/support?key=THIS_VALUE
DEVELOPER_SUPPORT_SECRET=
