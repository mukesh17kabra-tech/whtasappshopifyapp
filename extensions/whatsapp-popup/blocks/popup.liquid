{% comment %}
  WhatsApp Offer Popup — App Block
  Merchant adds this via Theme Editor > App Embeds. Content (heading,
  subheading, image, on/off) is controlled from the app's Popup Settings
  page, not block settings here — this fetches that config live on page load.
{% endcomment %}

<div id="wa-optin-popup" class="wa-optin-popup" style="display:none;">
  <div class="wa-optin-popup__box">
    <button type="button" class="wa-optin-popup__close" aria-label="Close">&times;</button>
    <img id="wa-optin-image" class="wa-optin-popup__image" width="400" height="200" style="display:none;" alt="" />
    <h3 id="wa-optin-heading">Get offers on WhatsApp</h3>
    <p id="wa-optin-subheading">Share your name and WhatsApp number to get offer alerts and order tracking updates.</p>
    <form id="wa-optin-form">
      <input type="text" id="wa-name" name="name" placeholder="Your name" required />
      <input type="tel" id="wa-phone" name="phone" placeholder="+91 98765 43210" required />
      <label class="wa-optin-consent">
        <input type="checkbox" id="wa-consent" required />
        I agree to receive offers and order updates on WhatsApp
      </label>
      <button type="submit">Notify me on WhatsApp</button>
      <p class="wa-optin-status" id="wa-optin-status"></p>
    </form>
  </div>
</div>

<script>
  (function () {
    var popup = document.getElementById('wa-optin-popup');
    var form = document.getElementById('wa-optin-form');
    var status = document.getElementById('wa-optin-status');
    var closeBtn = popup.querySelector('.wa-optin-popup__close');
    var headingEl = document.getElementById('wa-optin-heading');
    var subheadingEl = document.getElementById('wa-optin-subheading');
    var imageEl = document.getElementById('wa-optin-image');
    var STORAGE_KEY = 'wa_optin_dismissed';

    if (sessionStorage.getItem(STORAGE_KEY)) return;

    // Fetch merchant's current settings before deciding whether to show
    // anything at all — respects the on/off toggle from the app dashboard.
    fetch('/apps/whatsapp-offers/popup-config')
      .then(function (res) { return res.json(); })
      .then(function (config) {
        if (!config.enabled) return;

        if (config.heading) headingEl.textContent = config.heading;
        if (config.subheading) subheadingEl.textContent = config.subheading;
        if (config.imageUrl) {
          imageEl.src = config.imageUrl;
          imageEl.style.display = 'block';
        }

        setTimeout(function () {
          popup.style.display = 'flex';
        }, config.delayMs || 3000);
      })
      .catch(function () {
        // If the config fetch fails, don't show anything rather than
        // showing potentially stale/wrong default content.
      });

    closeBtn.addEventListener('click', function () {
      popup.style.display = 'none';
      sessionStorage.setItem(STORAGE_KEY, '1');
    });

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      var name = document.getElementById('wa-name').value.trim();
      var phone = document.getElementById('wa-phone').value.trim();
      var consent = document.getElementById('wa-consent').checked;

      status.textContent = 'Saving...';

      try {
        var res = await fetch('/apps/whatsapp-offers/optin', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: name, phoneNumber: phone, consent: consent }),
        });
        var data = await res.json();

        if (res.ok) {
          status.textContent = "You're in! We'll message you on WhatsApp.";
          sessionStorage.setItem(STORAGE_KEY, '1');
          setTimeout(function () { popup.style.display = 'none'; }, 1500);
        } else {
          status.textContent = data.error || 'Something went wrong.';
        }
      } catch (err) {
        status.textContent = 'Network error, please try again.';
      }
    });
  })();
</script>

<style>
  .wa-optin-popup {
    position: fixed; inset: 0; background: rgba(0,0,0,0.5);
    z-index: 9999; align-items: center; justify-content: center;
  }
  .wa-optin-popup__box {
    background: #fff; border-radius: 12px; padding: 24px; max-width: 360px;
    width: 90%; position: relative; text-align: center;
  }
  .wa-optin-popup__close {
    position: absolute; top: 8px; right: 12px; border: none; background: none;
    font-size: 22px; cursor: pointer;
  }
  .wa-optin-popup__image {
    width: 100%; border-radius: 8px; margin-bottom: 12px; display: block;
  }
  #wa-optin-form input[type="text"],
  #wa-optin-form input[type="tel"] {
    width: 100%; padding: 10px; margin: 8px 0; border: 1px solid #ccc; border-radius: 6px;
    box-sizing: border-box;
  }
  .wa-optin-consent { display: flex; align-items: center; gap: 8px; font-size: 12px; text-align: left; margin: 8px 0 12px; }
  #wa-optin-form button[type="submit"] {
    width: 100%; padding: 10px; background: #25D366; color: #fff; border: none;
    border-radius: 6px; font-weight: 600; cursor: pointer;
  }
</style>

{% schema %}
{
  "name": "WhatsApp Offer Popup",
  "target": "body",
  "settings": []
}
{% endschema %}
