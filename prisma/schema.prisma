generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")      // Neon pooled connection string
  directUrl = env("DIRECT_URL")        // Neon direct connection, used for migrations
}

// ---------- Required by @shopify/shopify-app-session-storage-prisma ----------
model Session {
  id                   String    @id
  shop                 String
  state                String
  isOnline             Boolean   @default(false)
  scope                String?
  expires              DateTime?
  accessToken          String
  refreshToken         String?
  refreshTokenExpires  DateTime?
  userId               BigInt?
  firstName            String?
  lastName             String?
  email                String?
  accountOwner         Boolean   @default(false)
  locale               String?
  collaborator         Boolean?  @default(false)
  emailVerified        Boolean?  @default(false)
}

// ---------- App-specific models ----------

model Shop {
  id           String   @id @default(cuid())
  shopDomain   String   @unique
  installedAt  DateTime @default(now())
  uninstalled  Boolean  @default(false)

  // WhatsApp connection via the bridge service — each merchant scans a QR
  // code to link their own real WhatsApp Business number, no Meta account,
  // no template approval. shopId (this row's id) is used as the session key
  // on the bridge service.
  whatsappBridgeConnected Boolean   @default(false)
  whatsappConnectedAt     DateTime?
  whatsappDisplayNumber   String?  // e.g. "+919876543210" — used for the storefront chatbot's "Continue on WhatsApp" link

  // Dev/testing only — lets you simulate a plan locally when Shopify's
  // Billing API is blocked (e.g. some dev store configurations return 403).
  // Never used as a source of truth once real billing is live; see
  // app.billing.tsx for how this is only consulted as a fallback.
  manualPlanOverride String?
  supportEmail       String? // merchant's own email — used as Reply-To on outgoing emails, since we send from our own verified domain

  optins        Optin[]
  ordersTrack   OrderTracking[]
  templates     Template[]
  broadcasts    Broadcast[]
  messageLogs   MessageLog[]
  popupSettings PopupSettings?
  supportMessages SupportMessage[]
  chatbotSettings ChatbotSettings?
  flows           Flow[]
}

model Optin {
  id               String    @id @default(cuid())
  shop             Shop      @relation(fields: [shopId], references: [id])
  shopId           String
  phoneNumber      String    // E.164 format, e.g. +919876543210
  email            String?   // captured from checkout, popup (if collected), or manual entry
  name             String?   // captured from the popup or checkout
  consentAt        DateTime  @default(now())
  source           String    // "popup" | "checkout" | "manual" | "csv_import" | "order"
  optedOutAt       DateTime?
  // Whether this number can receive MARKETING broadcasts. Popup/manual/CSV
  // default to true (explicit opt-in). Numbers captured automatically from
  // an order default to false — placing an order isn't marketing consent
  // under WhatsApp's rules or India's DPDP Act — but utility messages
  // (order confirmation, shipping) still go out regardless of this flag.
  marketingConsent Boolean   @default(true)

  @@unique([shopId, phoneNumber])
  @@index([shopId])
}

model PopupSettings {
  id          String   @id @default(cuid())
  shop        Shop     @relation(fields: [shopId], references: [id])
  shopId      String   @unique
  enabled     Boolean  @default(true)
  heading     String   @default("Get offers on WhatsApp")
  subheading  String   @default("Share your name and WhatsApp number to get offer alerts and order tracking updates.")
  imageUrl    String?
  delayMs     Int      @default(3000)
  updatedAt   DateTime @updatedAt
}

model OrderTracking {
  id               String   @id @default(cuid())
  shop             Shop     @relation(fields: [shopId], references: [id])
  shopId           String
  shopifyOrderId   String
  phoneNumber      String
  customerFirstName String?
  customerLastName  String?
  orderNumber      String?
  orderTotal       String?
  orderUrl         String?
  trackingNumber   String?
  trackingCompany  String?
  status           String   // "confirmed" | "shipped" | "out_for_delivery" | "delivered"
  trackingUrl      String?
  lastTemplateSent String?
  updatedAt        DateTime @updatedAt

  @@unique([shopId, shopifyOrderId])
  @@index([shopId, phoneNumber])
}

model Template {
  id                 String   @id @default(cuid())
  shop               Shop     @relation(fields: [shopId], references: [id])
  shopId             String
  name               String
  whatsappTemplateId String?  // Meta's template ID, filled in after successful submission
  category           String   // "MARKETING" | order category | "FLOW"
  channel            String   @default("whatsapp") // "whatsapp" | "email" | "both"
  subject            String?  // email subject line — only used when channel includes email
  status             String   @default("draft") // draft | pending | approved | rejected
  body               String   @default("") // message text with {variable} placeholders, composed in-app
  imageUrl           String?  // optional header image for the message
  variableKeys       String   @default("[]") // JSON array of {tag} names in order, e.g. ["first_name","order_id"]
  rejectionReason    String?  // Meta's feedback if status is "rejected"
  createdAt          DateTime @default(now())

  @@index([shopId])
}

model Broadcast {
  id              String   @id @default(cuid())
  shop            Shop     @relation(fields: [shopId], references: [id])
  shopId          String
  templateId      String
  status          String   @default("queued") // queued | sending | done | failed
  totalRecipients Int      @default(0)
  sentCount       Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([shopId])
}

model MessageLog {
  id                String   @id @default(cuid())
  shop              Shop     @relation(fields: [shopId], references: [id])
  shopId            String
  phoneNumber       String
  templateUsed      String
  status            String   // "sent" | "delivered" | "read" | "failed"
  providerMessageId String?
  sentAt            DateTime @default(now())

  @@index([shopId, phoneNumber])
}

model SupportMessage {
  id              String   @id @default(cuid())
  shop            Shop     @relation(fields: [shopId], references: [id])
  shopId          String
  sender          String   // "merchant" | "developer"
  body            String
  imageUrl        String?  // optional screenshot/image attachment
  createdAt       DateTime @default(now())
  readByMerchant  Boolean  @default(false)
  readByDeveloper Boolean  @default(false)

  @@index([shopId])
}

model ChatbotSettings {
  id            String   @id @default(cuid())
  shop          Shop     @relation(fields: [shopId], references: [id])
  shopId        String   @unique
  enabled       Boolean  @default(true)
  widgetColor   String   @default("#25D366")
  headerText    String   @default("Find your product")
  teaserMessage String   @default("Hello 👋 How can I help you?")
  bubbleIconUrl String?  // replaces the default 💬 bubble icon
  headerLogoUrl String?  // shown next to header text inside the chat window
  position      String   @default("bottom-right") // "bottom-right" | "bottom-left"
  updatedAt     DateTime @updatedAt
}

// ---------- Flow automation (Klaviyo-style) ----------

model Flow {
  id                  String     @id @default(cuid())
  shop                Shop       @relation(fields: [shopId], references: [id])
  shopId              String
  name                String
  trigger             String     // "ORDER_PLACED" — more triggers can be added later
  // Optional condition: only start this flow if the order contains this
  // specific product (Klaviyo-style trigger filter). Null = any product.
  triggerProductId    String?
  triggerProductTitle String?
  enabled             Boolean    @default(true)
  createdAt           DateTime   @default(now())
  steps               FlowStep[]
  runs                FlowRun[]

  @@index([shopId])
}

model FlowStep {
  id         String    @id @default(cuid())
  flow       Flow      @relation(fields: [flowId], references: [id])
  flowId     String
  position   Int       // order within the flow, 0-indexed
  type       String    // "DELAY" | "SEND_MESSAGE"
  delayDays  Int?      // used when type = "DELAY" and no sendDate is set
  sendDate   DateTime? // used when type = "DELAY" instead of delayDays — send on this specific date
  templateId String?   // used when type = "SEND_MESSAGE", references Template.id

  @@index([flowId])
}

// One FlowRun = one customer's journey through one Flow, starting from one
// trigger event (e.g. their specific order). Advances step by step, with
// QStash scheduling the next check after any DELAY step.
model FlowRun {
  id           String    @id @default(cuid())
  flow         Flow      @relation(fields: [flowId], references: [id])
  flowId       String
  shopId       String
  phoneNumber  String?
  email        String?
  customerName String?
  orderId      String?   // the order that triggered this run, if applicable
  currentStep  Int       @default(0)
  status       String    @default("active") // active | completed | cancelled
  nextRunAt    DateTime?
  createdAt    DateTime  @default(now())

  @@index([flowId])
  @@index([status, nextRunAt])
}
