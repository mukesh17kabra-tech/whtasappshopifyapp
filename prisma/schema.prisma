generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")      // Neon pooled connection string
  directUrl = env("DIRECT_URL")        // Neon direct connection, used for migrations
}

// ---------- Required by @shopify/shopify-app-session-storage-prisma ----------
model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

// ---------- App-specific models ----------

model Shop {
  id           String   @id @default(cuid())
  shopDomain   String   @unique
  installedAt  DateTime @default(now())
  uninstalled  Boolean  @default(false)

  // Per-merchant WhatsApp Business Account, connected via Meta's Embedded
  // Signup flow (see app/routes/app.whatsapp-connect.tsx). Each shop sends
  // through their own WhatsApp number/account, not a shared one — required
  // for listing this as a real multi-merchant Shopify app.
  whatsappPhoneNumberId      String?
  whatsappBusinessAccountId  String?
  whatsappAccessToken        String?  // long-lived token for this merchant's WABA
  whatsappDisplayPhoneNumber String?  // human-readable number, for display in the UI
  whatsappConnectedAt        DateTime?

  optins        Optin[]
  ordersTrack   OrderTracking[]
  templates     Template[]
  broadcasts    Broadcast[]
  messageLogs   MessageLog[]
  popupSettings PopupSettings?
}

model Optin {
  id           String    @id @default(cuid())
  shop         Shop      @relation(fields: [shopId], references: [id])
  shopId       String
  phoneNumber  String    // E.164 format, e.g. +919876543210
  name         String?   // captured from the popup alongside the number
  consentAt    DateTime  @default(now())
  source       String    // "popup" | "checkout" | "manual" | "csv_import"
  optedOutAt   DateTime?

  @@unique([shopId, phoneNumber])
  @@index([shopId])
}

model PopupSettings {
  id          String   @id @default(cuid())
  shop        Shop     @relation(fields: [shopId], references: [id])
  shopId      String   @unique
  enabled     Boolean  @default(true)
  heading     String   @default("Get offers on WhatsApp")
  subheading  String   @default("Share your name and WhatsApp number to get offer alerts and order tracking updates.")
  imageUrl    String?
  delayMs     Int      @default(3000)
  updatedAt   DateTime @updatedAt
}

model OrderTracking {
  id               String   @id @default(cuid())
  shop             Shop     @relation(fields: [shopId], references: [id])
  shopId           String
  shopifyOrderId   String
  phoneNumber      String
  status           String   // "confirmed" | "shipped" | "out_for_delivery" | "delivered"
  trackingUrl      String?
  lastTemplateSent String?
  updatedAt        DateTime @updatedAt

  @@unique([shopId, shopifyOrderId])
  @@index([shopId, phoneNumber])
}

model Template {
  id                 String   @id @default(cuid())
  shop               Shop     @relation(fields: [shopId], references: [id])
  shopId             String
  name               String
  whatsappTemplateId String?  // Meta's template ID, filled in after successful submission
  category           String   // "MARKETING" | "UTILITY"
  status             String   @default("draft") // draft | pending | approved | rejected
  body               String   @default("") // message text with {variable} placeholders, composed in-app
  imageUrl           String?  // optional header image for the message
  variableKeys       String   @default("[]") // JSON array of {tag} names in order, e.g. ["first_name","order_id"]
  rejectionReason    String?  // Meta's feedback if status is "rejected"
  createdAt          DateTime @default(now())

  @@index([shopId])
}

model Broadcast {
  id              String   @id @default(cuid())
  shop            Shop     @relation(fields: [shopId], references: [id])
  shopId          String
  templateId      String
  status          String   @default("queued") // queued | sending | done | failed
  totalRecipients Int      @default(0)
  sentCount       Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([shopId])
}

model MessageLog {
  id                String   @id @default(cuid())
  shop              Shop     @relation(fields: [shopId], references: [id])
  shopId            String
  phoneNumber       String
  templateUsed      String
  status            String   // "sent" | "delivered" | "read" | "failed"
  providerMessageId String?
  sentAt            DateTime @default(now())

  @@index([shopId, phoneNumber])
}
